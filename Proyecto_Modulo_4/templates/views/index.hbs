<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="container">
        <section class="card">
            <h1>{{title}}</h1>
            <p class="subtitle">Consulta el clima actual de cualquier ciudad usando Node.js, Express y WeatherStack.</p>

            <form id="weatherForm">
                <input id="address" type="text" placeholder="Ejemplo: Mexico City" autocomplete="off">
                <button type="submit">Buscar</button>
            </form>

            <div class="result">
                <p id="messageOne"></p>
                <p id="messageTwo"></p>
                <p id="messageThree"></p>
            </div>
        </section>

        <footer>
            <p>Creado por {{name}} - Proyecto Módulo 4</p>
        </footer>
    </main>

    <script src="/js/app.js"></script>
</body>
</html>